/* pages/index/index.wxss */
.page-container {
  background-color: #f8f8f8; /* 浅灰底色更有高级感 */
  min-height: 100vh;
}

/* 搜索栏 */
.search-section {
  padding: 100rpx 200rpx 20rpx 30rpx; 
  background-color: #f8f8f8; /* 保持和整体背景色一致 */
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 99;
}
.search-input-wrapper {
  flex: 1;
  height: 64rpx;
  background-color: #f4f4f4;
  border-radius: 36rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
}
.search-input {
  height: 100%;
  flex: 1;
  font-size: 28rpx;
}

.search-button {
  width: 120rpx !important; /* 关键：强制写死宽度，变小巧 */
  height: 64rpx !important;
  min-height: 64rpx !important; /* 覆盖微信默认样式 */
  line-height: 64rpx !important;
  margin-left: 20rpx !important;
  margin-right: 0 !important;
  padding: 0 !important; /* 去掉微信默认的左右大 padding */
  background-color: #333333; 
  color: white;
  font-size: 26rpx;
  border-radius: 32rpx;
  flex-shrink: 0; /* 关键：打死也不变形缩放 */
}










/* 轮播图 */
.swiper-container {
  width: 100%;
  height: 320rpx;
}
.swiper-ad-item {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 金刚区导航 */
.king-kong-section {
  padding: 40rpx 16rpx 30rpx 16rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}
.king-kong-grid {
  display: flex;
  justify-content: space-around;
  text-align: center;
}
.king-kong-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}
.king-kong-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}
.king-kong-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 瀑布流容器 */
.waterfall-container {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 0 20rpx;
}
.column {
  display: flex;
  flex-direction: column;
  width: calc(50% - 10rpx); /* 中间留出 20rpx 缝隙 */
}
.waterfall-item {
  width: 100%;
  margin-bottom: 20rpx;
  background-color: #e5e5ea; /* 骨架加载色 */
  border-radius: 16rpx; /* 卡片圆角 */
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  /* 核心防断裂 */
  break-inside: avoid;
  transform: translateZ(0); 
}
.item-image {
  width: 100%;
  height: 100%;
  display: block;
}



/* 回到顶部 */

.back-top-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx; /* 悬浮在右下角 */
  width: 88rpx;
  height: 88rpx;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px); /* 苹果味毛玻璃效果 */
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.back-top-icon {
  width: 44rpx;
  height: 44rpx;
}